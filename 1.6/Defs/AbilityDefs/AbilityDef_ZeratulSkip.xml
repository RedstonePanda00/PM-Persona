<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <!-- Same behavior as PMP_UmbraSkip (ProtossMech CompAbilityEffect_UmbraSkip); higher landing damage for PMPH_Zeratul -->
  <AbilityDef>
    <defName>PMPH_ZeratulSkip</defName>
    <label>void stride</label>
    <description>Phase to the targeted location, ignoring walls. Upon arrival, deal 100 execute damage to hostile pawns in a small radius. Every cell in a circular radius around the landing site is struck once by vanilla lightning, and a short-lived vanilla-style tornado with the same radius appears for 1 second.</description>
    <iconPath>UI/Abilities/Skip</iconPath>
    <cooldownTicksRange>300</cooldownTicksRange>
    <groupAbility>true</groupAbility>
    <hostile>false</hostile>
    <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <requireLineOfSight>false</requireLineOfSight>
      <range>25</range>
      <warmupTime>0.25</warmupTime>
      <targetParams>
        <canTargetLocations>true</canTargetLocations>
        <canTargetPawns>false</canTargetPawns>
        <canTargetBuildings>false</canTargetBuildings>
      </targetParams>
    </verbProperties>
    <comps>
      <li Class="ProtossMech.CompProperties_UmbraSkip">
        <damageAmount>100</damageAmount>
        <damageRadius>2.9</damageRadius>
        <damageDef>ExecutionCut</damageDef>
      </li>
      <li Class="PMP_Persona.CompProperties_ZeratulLandingLightning">
        <lightningRadius>3</lightningRadius>
        <tornadoDurationSeconds>2</tornadoDurationSeconds>
      </li>
    </comps>
  </AbilityDef>
</Defs>
