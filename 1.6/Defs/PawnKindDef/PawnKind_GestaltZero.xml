        </xenotypeSet>
        <combatPower>50</combatPower>
        <fixedGender>Male</fixedGender>
        <nameMaker>Name_GestalZero</nameMaker>
        <chemicalAddictionChance>0</chemicalAddictionChance>
        <maxPerGroup>1</maxPerGroup>
        <itemQuality>Masterwork</itemQuality>
        <isFighter>true</isFighter>
        <factionLeader>false</factionLeader>
        <maxGenerationAge>35</maxGenerationAge>
        <minGenerationAge>25</minGenerationAge>
        <apparelMoney>0~2500</apparelMoney>
        <apparelRequired>
            <li>Apparel_ArmorLocust</li>
            <li>Apparel_ArmorHelmetMechCommander</li>
            <li>Apparel_CollarShirt</li>
